    "check:cdn": "bash scripts/check-cdn.sh",
    "check:jsdoc": "bash scripts/check-jsdoc.sh"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "html-validate": "^8.18.0",
    "jsdom": "^24.0.0"
  }
}
