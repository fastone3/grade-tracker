{
  "name": "grade-tracker",
  "version": "1.7.0",
  "private": true,
  "description": "成绩追踪 & 积分系统 — 面向两个孩子的学习积分管理工具",
  "scripts": {
    "test": "node tests/run-all.js",
    "lint:js": "eslint index.js",
    "lint:html": "html-validate index.html",
